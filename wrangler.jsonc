{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bladeball-value-list",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-13",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": [
      "/",
      "/index.html",
      "/team",
      "/team/",
      "/team.html",
      "/privacy",
      "/privacy/",
      "/privacy.html",
      "/terms",
      "/terms/",
      "/terms.html",
      "/robots.txt",
      "/bots.txt",
      "/llms.txt",
      "/llm.txt",
      "/llms-full.txt",
      "/sitemap.xml",
      "/api/*",
      "/images/*",
      "/media/*"
    ]
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "bbtsl.lol/*",
      "zone_name": "bbtsl.lol"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bladeball-value-list",
      "database_id": "8526c5b5-390b-47e0-b462-7059e1c52209"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "bbtsl-media"
    }
  ],
  "vars": {
    "SITE_NAME": "BBTSL Blade Ball Top Spender List",
    "PUBLIC_SITE_URL": "https://bbtsl.lol",
    "DISCORD_REDIRECT_URI": "https://bbtsl.lol/api/auth/callback"
  }
}
